# =============================================================
# ЭкоПульс — пример .env
# Скопируй в .env (на VPS / локально) и заполни реальными значениями.
# .env защищён .gitignore — никогда не коммить.
# =============================================================

# --- БД (postgres) ---
# Эти три читает docker-compose для инициализации postgres-контейнера:
POSTGRES_USER=dedecolog
POSTGRES_PASSWORD=change-me-strong-24+chars
POSTGRES_DB=dedecolog
# DATABASE_URL читает бек. Для compose: host=db (имя сервиса). Локально: localhost.
DATABASE_URL=postgresql+asyncpg://dedecolog:change-me-strong-24+chars@db:5432/dedecolog

# --- Redis (очередь синхронизации МНО) ---
# arq-воркер + общий прогресс фоновой синхронизации МНО между uvicorn-воркерами
# (переживает рестарты, умеет возобновляться). Для compose: host=redis (имя сервиса).
REDIS_URL=redis://redis:6379/0

# --- Аутентификация ---
# JWT_SECRET сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-prod
# FERNET_KEY (опционально) — ключ шифрования секретов в БД (пароль SMTP из настроек UI).
# Пусто → детерминированно деривируется из JWT_SECRET (работает «из коробки»). В проде
# лучше задать явный ключ (тогда ротация JWT_SECRET не обесценит зашифрованные секреты):
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Блокировка входа: 5 неудач → 15 минут locked_until.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Сид-админ (создаётся python -m app.seed, status=active, role=admin) ---
SEED_ADMIN_EMAIL=admin@dedekolog.ru
SEED_ADMIN_PASSWORD=change-me-admin-password

# --- Деплой ---
# Список origin'ов фронта через запятую.
# Прод по IP (nginx фронта проксирует /api → бэк, тот же origin) — CORS фактически не задействован,
# но укажи свой адрес на всякий: например http://203.0.113.10:8888
# Dev: http://localhost:5173 (vite) + http://localhost:8080 (nginx в docker).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# HTTP по IP → ОБЯЗАТЕЛЬНО False (иначе refresh-cookie с флагом Secure не уйдёт и сессия сломается).
# Завтра при домене+HTTPS → поставь True.
SESSION_COOKIE_SECURE=False

# Токен приёма вебхуков Яндекс-Формы (заголовок X-Intake-Token). Сгенерируй: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
YANDEX_INTAKE_TOKEN=change-me-intake-token

# DaData API-ключ (dadata.ru) — включает автозаполнение адреса в публичной форме. Пусто = ручной ввод.
DADATA_API_KEY=
# Секретный ключ DaData — для Clean API, разбор адреса из Макс-сообщений (нужны ОБА ключа). Пусто = эвристический разбор.
DADATA_SECRET_KEY=

# --- Почта волонтёров (плагинный mailer, env-конфиг) ---
# ВНИМАНИЕ: это ОТДЕЛЬНЫЙ канал от почтового сервера, настраиваемого в UI («Настройки → Почта
# (SMTP)», таблица smtp_settings, только admin, с тестовым письмом). Эти SMTP_* env-переменные
# питают ТОЛЬКО mailer писем волонтёрам (verify/reset). Оба канала независимы.
# Пока SMTP пуст → письма подтверждения почты/сброса пароля НЕ отправляются (mailer честно
# возвращает False), а токен/ссылка возвращаются в ответе эндпоинта (email_sent=false) для
# интеграции/тестов. Заполни SMTP_HOST и SMTP_FROM (и при необходимости порт/логин/пароль)
# → письма уйдут реально (smtplib STARTTLS), токен из ответа исчезнет.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Базовый публичный URL приложения — из него собираются ссылки verify/reset в письмах волонтёрам.
APP_PUBLIC_URL=https://ecopulse.reo.ru

# --- claude CLI (мотивирующая цитата) ---
# На успешном приёме обращения бэк генерирует короткую цитату о природе через
# `claude --print`. Папка с токеном монтируется в контейнер через CLAUDE_TOKEN_DIR
# в docker-compose. При недоступности CLI бэк отдаёт реальную цитату из фолбэка.
# Папка на ХОСТЕ с токеном claude (симлинк), монтируется в контейнер как /app/claude-auth (ro).
CLAUDE_TOKEN_DIR=/data
# Путь к токен-файлу claude ВНУТРИ контейнера (JSON {access_token}). Напр. /app/claude-auth/.claude_token.json
CLAUDE_TOKEN_FILE=
# Фолбэк-токен из `claude setup-token` (если не используешь CLAUDE_TOKEN_FILE).
CLAUDE_CODE_OAUTH_TOKEN=
# Модель для генерации цитаты (быстрая/дешёвая).
CLAUDE_QUOTE_MODEL=haiku
# Модель для РАЗБОРА адреса из свободного текста Макс-обращения (мощнее haiku —
# грязный текст с ФИО/датой/описанием). Цитаты остаются на CLAUDE_QUOTE_MODEL.
CLAUDE_PARSE_MODEL=sonnet

# --- Макс-бот (сервис maxbot, профиль "maxbot") ---
# Токен бота с https://dev.max.ru (для бота id5408285792_3_bot). Нужен ТОЛЬКО сервису maxbot.
# Бот шлёт обращения в бэк по X-Intake-Token = YANDEX_INTAKE_TOKEN (передаётся в compose).
MAX_BOT_TOKEN=
# ID группы Макс для уведомлений о новых обращениях (бот должен быть админом этой группы).
MAX_GROUP_CHAT_ID=-75787158905457

# --- Frontend (build-time, читает Vite при СБОРКЕ образа) ---
# Прод (docker, заход по IP): относительный путь — фронт и API на одном origin :8888.
VITE_API_BASE_URL=/api/v1
# Локальный `npm run dev` (vite :5173, без nginx): http://localhost:8000/api/v1

# Ключ Yandex Maps JS API 2.1 (тип ключа «JavaScript API и HTTP Геокодер», кабинет
# developer.tech.yandex.ru). Зашивается в бандл при сборке — это нормально для JS-Карт;
# ОБЯЗАТЕЛЬНО ограничьте ключ по домену (ecopulse.reo.ru) в кабинете Яндекса.
# Пусто → карта на экранах «МНО» и «Инциденты» честно показывает плашку «Карта недоступна».
VITE_YANDEX_MAPS_KEY=
