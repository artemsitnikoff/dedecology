# MAX bot token (from https://dev.max.ru)
MAX_BOT_TOKEN=

# Backend intake endpoint (inside the compose network backend is `backend:8000`)
INTAKE_URL=http://backend:8000/api/v1/intake/max

# Shared secret — MUST equal the backend YANDEX_INTAKE_TOKEN
INTAKE_TOKEN=

# Max downloaded photo size in bytes (default 20 MiB)
MAX_PHOTO_BYTES=20971520
